# Copy this file to .env.production on the server and fill in strong values.

SESSION_SECRET_KEY=replace-with-a-long-random-secret
SESSION_HTTPS_ONLY=1
SESSION_SAMESITE=lax

PASSWORD_HASH_SCHEME=argon2id
PASSWORD_PEPPER=replace-with-another-long-random-secret
BCRYPT_ROUNDS=12

REDIS_PASSWORD=

# Optional: restrict admin routes to your own IP addresses.
# Example:
# ADMIN_IP_ALLOWLIST=127.0.0.1,::1,49.36.10.20
ADMIN_IP_ALLOWLIST=

# Optional: if you add hCaptcha later.
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

